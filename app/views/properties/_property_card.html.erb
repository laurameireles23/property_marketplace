<div class="col-12 col-md-6 col-lg-4">
  <div class="card h-100 shadow-lg border-0">
    <div class="card-body d-flex flex-column">
      <h5 class="card-title fw-bold mb-1"><%= property.title %></h5>
      <p class="text-muted mb-1"><%= property.address %></p>
      <h4 class="text-success fw-bold mb-2">R$ <%= number_with_precision(property.price, precision: 2, delimiter: '.') %></h4>
      <p class="mb-3 text-muted">Vendedor: <%= property.user.name %></p>
      <div class="mt-auto">
        <div class="d-flex gap-2 flex-wrap">
          <%= link_to raw('<i class="bi bi-eye"></i> Ver'), property_path(property), class: "btn btn-outline-primary flex-fill" %>
          <% unless property.offers.any? { |o| o.status == 'accepted' } %>
            <%= link_to raw('<i class="bi bi-currency-dollar"></i> Ter Oferta'), new_property_offer_path(property), class: "btn btn-outline-success flex-fill" %>
          <% end %>
          <%= link_to raw('<i class="bi bi-pencil"></i> Editar'), edit_property_path(property), class: "btn btn-outline-warning flex-fill" %>
          <%= form_with url: property_path(property), method: :delete, local: true, class: "d-inline" do |f| %>
            <%= f.submit ("Remover").html_safe, class: "btn btn-outline-danger flex-fill", data: { confirm: 'Tem certeza?' } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<%= simple_form_for [@property, @offer] do |f| %>
  <div class="row">
    <div class="col-12 mb-4">
      <%= f.input :user_id, collection: @compradores, label: 'Comprador', as: :select, prompt: 'Selecione o comprador', required: true, input_html: { class: 'form-select' }, value_method: :id, label_method: :name %>
    </div>
    <div class="col-12 mb-4">
      <%= f.input :value, label: 'Valor da Oferta', wrapper: false,
          input_html: { class: 'form-control' } %>
    </div>
  </div>
  <div class="d-flex justify-content-end gap-2">
    <%= link_to @property, class: "btn btn-secondary" do %>Cancelar<% end %>
    <%= f.button :submit, (local_assigns[:submit_label] || 'Enviar Oferta'), class: "btn btn-success" %>
  </div>
<% end %>
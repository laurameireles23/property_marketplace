<div class="row">
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header bg-white">
        <div class="d-flex justify-content-between align-items-center">
          <h1 class="h3 mb-0 text-dark">Usuários</h1>
          <%= link_to "Novo Usuário", new_user_path, class: "btn btn-primary" %>
        </div>
      </div>
      <div class="card-body">
        <% if @users.any? %>
          <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% @users.each do |user| %>
              <div class="col">
                <div class="card h-100 shadow-sm hover-shadow">
                  <div class="card-body">
                    <h5 class="card-title">
                      <%= link_to user.name, user_path(user), class: "text-decoration-none" %>
                    </h5>
                    <p class="card-text text-muted mb-2">
                      <i class="bi bi-envelope"></i> <%= user.email %>
                    </p>
                    <p class="card-text text-muted mb-3">
                      <i class="bi bi-telephone"></i> <%= user.phone %>
                    </p>
                    <span class="badge
                      <%= user.user_type == 'vendedor' ? 'bg-primary' : 'bg-success' %>">
                      <%= user.user_type.humanize %>
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-5">
            <div class="mb-4">
              <i class="bi bi-people display-1 text-muted"></i>
            </div>
            <h4 class="text-muted mb-3">Nenhum usuário encontrado</h4>
            <p class="text-muted mb-4">Comece cadastrando o primeiro usuário no sistema!</p>
            <%= link_to "Criar primeiro usuário", new_user_path, class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">
    <div class="card shadow">
      <div class="card-header bg-white">
        <h1 class="h3 mb-0 text-dark">Novo Usuário</h1>
      </div>
      <div class="card-body">
        <%= simple_form_for @user do |f| %>
          <div class="row">
            <div class="col-12 mb-3">
              <%= f.input :name, label: 'Nome', wrapper: false,
                  input_html: { class: 'form-control' } %>
            </div>
            <div class="col-12 mb-3">
              <%= f.input :email, label: 'Email', wrapper: false,
                  input_html: { class: 'form-control' } %>
            </div>
            <div class="col-12 mb-3">
              <%= f.input :phone, label: 'Telefone', wrapper: false,
                  input_html: { class: 'form-control' } %>
            </div>
            <div class="col-12 mb-4">
              <%= f.input :user_type, label: 'Tipo de Usuário',
                  collection: [['Comprador', 'comprador'], ['Vendedor', 'vendedor']],
                  wrapper: false, input_html: { class: 'form-select' } %>
            </div>
          </div>

          <div class="d-flex justify-content-end gap-2">
            <%= link_to "Cancelar", users_path, class: "btn btn-secondary" %>
            <%= f.button :submit, "Criar Usuário", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>